# Environment configuration
NODE_ENV=production

# Server port (Railway/Render will set this automatically)
PORT=3000

# CORS - comma-separated list of allowed origins for production
# NEVER use * in production — list your actual origins
# Example: https://yourgame.com,https://www.yourgame.com
ALLOWED_ORIGINS=

# Admin key for protected endpoints — use a strong random secret (32+ chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_RESET_KEY=

# Game client API key — shared secret between game and server
# Leave empty to disable (allow all clients). Set to activate enforcement.
# The game client must send this in the x-api-key header.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
GAME_API_KEY=

# Optional: Anthropic API key for AI crash analysis
ANTHROPIC_API_KEY=